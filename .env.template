# ============================================================
# InstaAgent — Environment Variables Template
# Niche: Travel & Adventure (@karadenizli.maceraci)
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Meta / Instagram ─────────────────────────────────────────
# Long-lived access token from Meta Developer Console
# Exchange a short-lived token via:
# GET https://graph.facebook.com/v21.0/oauth/access_token
#     ?grant_type=fb_exchange_token&client_id=APP_ID
#     &client_secret=APP_SECRET&fb_exchange_token=SHORT_TOKEN
META_ACCESS_TOKEN=your_meta_long_lived_access_token_here

# Your Instagram Business/Creator Account ID (numeric)
# For food.timeez: 
IG_ACCOUNT_ID=

# ── Cloudinary ───────────────────────────────────────────────
# Get these from your Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=food.timeez/reposts

# ── Facebook Page ─────────────────────────────────────────────
# Food.timeez FB Page — ID: 1108089925717026
# NOTE: Facebook posting is currently paused (facebook.enabled: false in config.yaml)
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=1108089925717026

# ── YouTube Channel ────────────────────────────────────────────
# OAuth2 credentials from Google Cloud Console (youtube.upload scope)
# Step 1: Create an OAuth2 "Desktop app" client at console.cloud.google.com
# Step 2: Enable "YouTube Data API v3" in the project
# Step 3: Run `python tools/yt_auth.py` once locally to generate your refresh token
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=

# ── Repost Scraping ──────────────────────────────────────────
# A secondary/burner IG account for read-only scraping.
# RECOMMENDED: Use IG_SESSION_ID (browser cookie) to bypass IP blacklisting.
IG_SESSION_ID=

# Fallback: username + password (may be blocked on new IPs)
IG_SCRAPE_USER=
IG_SCRAPE_PASS=
