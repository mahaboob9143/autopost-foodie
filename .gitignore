# Secrets — NEVER commit
.env

# Database
*.db
*.sqlite
*.sqlite3

# Downloaded media — never commit these
media/reposts/*
media/temp*
!media/reposts/.gitkeep

# Logs
logs/*
!logs/.gitkeep

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
